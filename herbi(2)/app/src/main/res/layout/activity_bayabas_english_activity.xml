<?xml version="1.0" encoding="UTF-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable name="bayabasEnglishVMVM" type="com.herbi.app.modules.bayabasenglishactivity.data.viewmodel.BayabasEnglishVMVM"/>
    </data>
    <FrameLayout android:id="@+id/frameBayabasEnglish"
        android:layout_height="match_parent"
        android:layout_width="match_parent" style="@style/groupStylewhite_A700">
        <LinearLayout android:id="@+id/linearColumnlogog"
            android:layout_gravity="top|start"
            android:layout_height="match_parent"
            android:layout_marginBottom="@dimen/_10pxv"
            android:layout_marginTop="@dimen/_3pxv"
            android:layout_width="match_parent" android:orientation="vertical">
            <androidx.appcompat.widget.Toolbar
                android:gravity="center_horizontal"
                android:id="@+id/toolbarToolbar"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_15pxh"
                android:layout_marginStart="@dimen/_15pxh"
                android:layout_width="match_parent" app:contentInsetStart="0dp">
                <LinearLayout android:gravity="start"
                    android:id="@+id/linearRowlogog"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent" android:orientation="horizontal">
                    <ImageView android:id="@+id/imageLogog"
                        android:layout_height="@dimen/_40pxh"
                        android:layout_width="@dimen/_40pxh"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_logog"
                        tools:ignore="ContentDescription" tools:src="@drawable/img_logog"/>
                    <TextView android:ellipsize="end"
                        android:id="@+id/txtUnlockingtheH"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_7pxv"
                        android:layout_marginStart="@dimen/_34pxh"
                        android:layout_marginTop="@dimen/_16pxv"
                        android:layout_weight="0.86"
                        android:layout_width="0dp"
                        android:singleLine="true"
                        android:text="@{bayabasEnglishVMVM.bayabasEnglishModelModel.txtUnlockingtheH}"
                        style="@style/txtNunitoitalicregular11" tools:text="@string/msg_unlocking_the_h"/>
                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>
            <FrameLayout android:gravity="start"
                android:id="@+id/frameStackarrowleft"
                android:layout_height="@dimen/_35pxv" android:layout_width="match_parent">
                <LinearLayout android:id="@+id/linearRowarrowleft"
                    android:layout_gravity="bottom|start"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_3pxv"
                    android:layout_marginTop="@dimen/_10pxv"
                    android:layout_width="match_parent"
                    android:orientation="horizontal" style="@style/groupStyleteal_700">
                    <ImageView android:id="@+id/imageArrowleft"
                        android:layout_height="@dimen/_12pxh"
                        android:layout_marginBottom="@dimen/_6pxv"
                        android:layout_marginStart="@dimen/_11pxh"
                        android:layout_marginTop="@dimen/_7pxv"
                        android:layout_width="@dimen/_17pxh"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_arrowleft"
                        tools:ignore="ContentDescription" tools:src="@drawable/img_arrowleft"/>
                    <TextView android:ellipsize="end"
                        android:id="@+id/txtFilipino"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_8pxv"
                        android:layout_marginEnd="@dimen/_19pxh"
                        android:layout_marginStart="@dimen/_279pxh"
                        android:layout_marginTop="@dimen/_4pxv"
                        android:layout_weight="0.66"
                        android:layout_width="0dp"
                        android:singleLine="true"
                        android:text="@{bayabasEnglishVMVM.bayabasEnglishModelModel.txtFilipino}"
                        style="@style/txtNunitoregular10" tools:text="@string/lbl_filipino"/>
                </LinearLayout>
                <View android:background="@color/white_A700"
                    android:id="@+id/viewRectangleNinety"
                    android:layout_gravity="end"
                    android:layout_height="@dimen/_33pxv"
                    android:layout_marginBottom="@dimen/_1pxv"
                    android:layout_marginEnd="@dimen/_33pxh"
                    android:layout_marginStart="@dimen/_33pxh"
                    android:layout_marginTop="@dimen/_1pxv" android:layout_width="@dimen/_37pxh"/>
                <ImageView android:id="@+id/imageRectangleNinetyOne"
                    android:layout_gravity="end"
                    android:layout_height="@dimen/_35pxh"
                    android:layout_marginEnd="@dimen/_34pxh"
                    android:layout_marginStart="@dimen/_34pxh"
                    android:layout_width="@dimen/_35pxh"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_rectangle92"
                    tools:ignore="ContentDescription" tools:src="@drawable/img_rectangle92"/>
            </FrameLayout>
            <FrameLayout android:gravity="start"
                android:id="@+id/frameStackmalunggay"
                android:layout_height="@dimen/_212pxv"
                android:layout_marginTop="@dimen/_2pxv" android:layout_width="match_parent">
                <ImageView android:id="@+id/imageMalunggay"
                    android:layout_gravity="start"
                    android:layout_height="@dimen/_177pxv"
                    android:layout_marginBottom="@dimen/_17pxv"
                    android:layout_marginTop="@dimen/_17pxv"
                    android:layout_width="match_parent"
                    android:scaleType="fitXY"
                    cornerRadius="@{@dimen/_3pxh}"
                    imageRes="@{@drawable/img_malunggay_4}"
                    tools:ignore="ContentDescription" tools:src="@drawable/img_malunggay_4"/>
                <LinearLayout android:id="@+id/linearColumnlanguage"
                    android:layout_gravity="top|start"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_10pxv"
                    android:layout_marginTop="@dimen/_1pxv"
                    android:layout_width="match_parent"
                    android:orientation="vertical" style="@style/groupStyleteal_701">
                    <TextView android:ellipsize="end"
                        android:gravity="start"
                        android:id="@+id/txtLanguage"
                        android:layout_height="match_parent"
                        android:layout_marginBottom="@dimen/_7pxv"
                        android:layout_marginEnd="@dimen/_49pxh"
                        android:layout_marginStart="@dimen/_49pxh"
                        android:layout_marginTop="@dimen/_1pxv"
                        android:layout_width="match_parent"
                        android:lineSpacingExtra="@dimen/_5pxh"
                        android:singleLine="true"
                        android:text="@{bayabasEnglishVMVM.bayabasEnglishModelModel.txtLanguage}"
                        style="@style/txtNunitolight12_1" tools:text="@string/lbl_herb_name"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/linearColumnlanguageOne"
                    android:layout_gravity="bottom|start"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10pxv"
                    android:layout_width="match_parent"
                    android:orientation="vertical" style="@style/groupStyleteal_701">
                    <TextView android:ellipsize="end"
                        android:gravity="start"
                        android:id="@+id/txtLanguageOne"
                        android:layout_height="match_parent"
                        android:layout_marginBottom="@dimen/_6pxv"
                        android:layout_marginEnd="@dimen/_32pxh"
                        android:layout_marginStart="@dimen/_32pxh"
                        android:layout_marginTop="@dimen/_1pxv"
                        android:layout_width="match_parent"
                        android:lineSpacingExtra="@dimen/_5pxh"
                        android:singleLine="true"
                        android:text="@{bayabasEnglishVMVM.bayabasEnglishModelModel.txtLanguageOne}"
                        style="@style/txtNunitoregular12" tools:text="@string/msg_scientific_name"/>
                </LinearLayout>
                <TextView android:ellipsize="end"
                    android:id="@+id/txtGuava"
                    android:layout_gravity="top|end"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_10pxv"
                    android:layout_marginEnd="@dimen/_136pxh"
                    android:layout_marginStart="@dimen/_136pxh"
                    android:layout_width="wrap_content"
                    android:lineSpacingExtra="@dimen/_6pxh"
                    android:singleLine="true"
                    android:text="@{bayabasEnglishVMVM.bayabasEnglishModelModel.txtGuava}"
                    style="@style/txtNunitobold15" tools:text="@string/lbl_guava"/>
                <TextView android:ellipsize="end"
                    android:id="@+id/txtPsidiumGuajava"
                    android:layout_gravity="bottom|end"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_4pxv"
                    android:layout_marginEnd="@dimen/_95pxh"
                    android:layout_marginStart="@dimen/_95pxh"
                    android:layout_marginTop="@dimen/_10pxv"
                    android:layout_width="wrap_content"
                    android:lineSpacingExtra="@dimen/_6pxh"
                    android:singleLine="true"
                    android:text="@{bayabasEnglishVMVM.bayabasEnglishModelModel.txtPsidiumGuajava}"
                    style="@style/txtNunitobold15" tools:text="@string/lbl_psidium_guajava"/>
            </FrameLayout>
            <TextView android:ellipsize="end" android:gravity="start"
                android:id="@+id/txtGroup546"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10pxv"
                android:layout_width="match_parent"
                android:lineSpacingExtra="@dimen/_6pxh"
                android:paddingBottom="@dimen/_2pxv"
                android:paddingEnd="@dimen/_30pxh"
                android:paddingStart="@dimen/_30pxh"
                android:paddingTop="@dimen/_1pxv"
                android:singleLine="true"
                android:text="@{bayabasEnglishVMVM.bayabasEnglishModelModel.txtGroup546}"
                style="@style/txtSolidOutline" tools:text="@string/lbl_description"/>
            <TextView android:gravity="center_horizontal"
                android:id="@+id/txtDescriptionOne"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_15pxh"
                android:layout_marginStart="@dimen/_15pxh"
                android:layout_marginTop="@dimen/_12pxv"
                android:layout_width="match_parent"
                android:lineSpacingExtra="@dimen/_5pxh"
                android:text="@{bayabasEnglishVMVM.bayabasEnglishModelModel.txtDescriptionOne}"
                style="@style/txtNunitoregular13" tools:text="@string/msg_guava_leaves_ar"/>
            <TextView android:ellipsize="end" android:gravity="start"
                android:id="@+id/txtLanguageTwo"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_14pxv"
                android:layout_width="match_parent"
                android:lineSpacingExtra="@dimen/_6pxh"
                android:paddingBottom="@dimen/_2pxv"
                android:paddingEnd="@dimen/_30pxh"
                android:paddingStart="@dimen/_30pxh"
                android:paddingTop="@dimen/_1pxv"
                android:singleLine="true"
                android:text="@{bayabasEnglishVMVM.bayabasEnglishModelModel.txtLanguageTwo}"
                style="@style/txtSolidOutline_1" tools:text="@string/lbl_medicinal_uses"/>
            <TextView android:gravity="center_horizontal"
                android:id="@+id/txtDescriptionTwo"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_15pxh"
                android:layout_marginStart="@dimen/_15pxh"
                android:layout_marginTop="@dimen/_10pxv"
                android:layout_width="match_parent"
                android:lineSpacingExtra="@dimen/_5pxh"
                android:text="@{bayabasEnglishVMVM.bayabasEnglishModelModel.txtDescriptionTwo}"
                style="@style/txtNunitoregular13" tools:text="@string/msg_guava_leaves_ha"/>
        </LinearLayout>
    </FrameLayout>
</layout>
